# Copy this file to .env (same folder as test_client.py) and fill in both values.
# Both values are emitted as ARM deployment outputs when the lab starts — see
# Exercise 1 Step 4 for the az CLI commands that read them.

# Full Foundry project endpoint, including the /api/projects/<name> suffix.
# Example: https://smuai103l8acctab12cd.services.ai.azure.com/api/projects/summitline-agents
PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/summitline-agents

# Name of the gpt-4.1-mini model deployment on the Foundry account.
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
