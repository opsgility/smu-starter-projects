# Foundry project endpoint, e.g.
# https://summitline-aif-xxxxx.services.ai.azure.com/api/projects/summitline-proj
PROJECT_ENDPOINT=

# Name of the gpt-4.1-mini deployment on the Foundry account (default: gpt-4.1-mini)
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Full resource ID of the Foundry project connection that targets your AI Search service.
# Format:
#   /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<foundry-account>/projects/<project>/connections/<connection-name>
AZURE_SEARCH_CONNECTION_ID=

# Name of the Azure AI Search index the AzureAISearchTool should query.
AZURE_SEARCH_INDEX_NAME=summitline-kb

# Content Understanding endpoint, typically the Foundry account's
# cognitiveservices.azure.com endpoint, e.g.
#   https://summitline-aif-xxxxx.cognitiveservices.azure.com
CU_ENDPOINT=

# Ocp-Apim-Subscription-Key for the Foundry AIServices account (key1 or key2).
# Content Understanding in eastus2 still requires a key header (AAD not yet GA).
CU_KEY=

# Content Understanding REST API version.
CU_API_VERSION=2024-12-01-preview
