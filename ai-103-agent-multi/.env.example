# Summitline Outfitters multi-agent concierge — environment contract.
# Populate these from the AI-103 L10 ARM deployment outputs in Exercise 3391 Step 4.

# Foundry project endpoint, e.g.
# https://smtl-foundry-ab12cd.services.ai.azure.com/api/projects/smtl-proj-ab12cd
PROJECT_ENDPOINT=

# gpt-4.1 deployment name as reported by the ARM template output
# (the AI-103 L10 template pins this to "gpt-4.1").
MODEL_DEPLOYMENT_NAME=gpt-4.1

# Full Application Insights connection string — must include InstrumentationKey,
# IngestionEndpoint, and LiveEndpoint (not just the instrumentation key GUID).
APPLICATIONINSIGHTS_CONNECTION_STRING=
