# Summitline Outfitters capstone — environment variables
# Exercise 1 Step 3 appends every value to this file after harvesting deployment outputs.
# Do NOT commit a populated .env; see .gitignore.

# Application Insights (OTel) — configured at import time by app/tracing.py
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://eastus2-0.in.applicationinsights.azure.com/

# Azure AI Foundry project (AIProjectClient + AgentsClient)
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>

# Model deployments on that Foundry account
MODEL_DEPLOYMENT=gpt-4.1
MODEL_DEPLOYMENT_NAME=gpt-4.1
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure AI Search (used by /rag directly, and by /agent via the project connection)
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_INDEX=summitline-kb
AZURE_SEARCH_SERVICE_NAME=<search-service>
# Populated in Exercise 2 Step 1 (project connection PUT)
AZURE_SEARCH_CONNECTION_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<foundry-account>/projects/<project-name>/connections/summitline-search

# Storage (for doc pipelines, seed script, etc.)
AZURE_STORAGE_ACCOUNT=<storage-account>
AZURE_STORAGE_CONTAINER=summitline-docs

# Content Understanding (served by the same AIServices account)
CU_ENDPOINT=https://<foundry-account>.cognitiveservices.azure.com
CU_KEY=<ai-services-primary-key>

# Speech SDK (served by the same AIServices account)
SPEECH_KEY=<ai-services-primary-key>
SPEECH_REGION=eastus2
SPEECH_VOICE=en-US-JennyNeural
