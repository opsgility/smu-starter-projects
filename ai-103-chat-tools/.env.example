# Copy this file to `.env` in the same folder and fill in the values from
# the lab's ARM deployment outputs (see Exercise 1, Step 4).
#
# The project endpoint MUST have the shape
#   https://<svc>.services.ai.azure.com/api/projects/<project-name>
# NOT the services root. The Responses API lives at the project scope.
AZURE_AI_PROJECT_ENDPOINT=https://your-foundry.services.ai.azure.com/api/projects/summitline-chat-tools

# Must match the exact (case-sensitive) deployment name in the Foundry
# portal. The lab's ARM template defaults to `gpt-4.1-mini`.
MODEL_DEPLOYMENT=gpt-4.1-mini
