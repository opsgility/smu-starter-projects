# -----------------------------------------------------------------------------
# Content Understanding (key auth - keyless CU is not yet GA)
# -----------------------------------------------------------------------------
CU_ENDPOINT=https://<foundry-account>.services.ai.azure.com
CU_KEY=<foundry-account-key>
CU_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------------
# Foundry project + model deployments (keyless via DefaultAzureCredential)
# -----------------------------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_SERVICES_ENDPOINT=https://<foundry-account>.services.ai.azure.com
MODEL_DEPLOYMENT=gpt-4.1
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# -----------------------------------------------------------------------------
# Azure AI Search
# -----------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_INDEX=summitline-knowledge

# -----------------------------------------------------------------------------
# Source blob storage
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=<storage-account-name>
AZURE_STORAGE_CONTAINER=ai103-source
