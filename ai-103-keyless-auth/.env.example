# Summitline Outfitters concierge — AI-103 Lab 2258 (Lesson 4 keyless auth)
#
# Copy this file to `.env` and populate from the baseline ARM deployment
# outputs (Exercise 1 step 3). After migration you should NOT have
# AZURE_OPENAI_API_KEY or AZURE_OPENAI_ENDPOINT set anywhere.

# Foundry project endpoint — e.g.
#   https://<foundryAccountName>.services.ai.azure.com/api/projects/<projectName>
AZURE_AI_PROJECT_ENDPOINT=

# Name of the gpt-4.1 deployment attached to the Foundry project.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Foundry AI Services account name (hub) — used as the `hubName` parameter
# when deploying bicep/identity.bicep in Exercise 2.
FOUNDRY_ACCOUNT=
