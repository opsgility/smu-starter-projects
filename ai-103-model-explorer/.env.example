# Azure AI Foundry project endpoint — data-plane URL for the Foundry project.
# Shape: https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
# Populated from the ARM template output `projectEndpoint` (Exercise 1, step 6).
AZURE_AI_PROJECT_ENDPOINT=https://REPLACE-ME.services.ai.azure.com/api/projects/REPLACE-ME

# Comma-separated list of model deployment names created by the lab's ARM template.
# Populated from the ARM template output `modelDeploymentNames` (Exercise 1, step 6).
# Expected default: gpt-4.1-mini,gpt-4o,gpt-4.1-nano
MODEL_DEPLOYMENTS=gpt-4.1-mini,gpt-4o,gpt-4.1-nano
