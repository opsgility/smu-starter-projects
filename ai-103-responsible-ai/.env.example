# Foundry project endpoint — must end with /api/projects/<project-name>
# e.g. https://ai103rai-fdy-abcd1234.services.ai.azure.com/api/projects/rai-project
AZURE_AI_PROJECT_ENDPOINT=

# Dedicated Content Safety account endpoint (separate from the Foundry account)
# e.g. https://ai103rai-cs-abcd1234.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_ENDPOINT=

# Content Safety account key (listKeys output from ARM deployment)
AZURE_CONTENT_SAFETY_KEY=

# Model deployment name on the Foundry account (Exercise 1 uses gpt-4.1-mini)
MODEL_DEPLOYMENT=gpt-4.1-mini

# Path to the evaluation dataset used by app/evals.py
EVAL_DATASET=eval_data.jsonl
