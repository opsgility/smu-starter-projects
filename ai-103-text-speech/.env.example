# ---------------------------------------------------------------------------
# AI-103 Lesson 12 — Summitline Outfitters text + speech service
# Copy this file to `.env` and fill in the values captured from ARM outputs
# and `az cognitiveservices account keys list` calls in each exercise.
# ---------------------------------------------------------------------------

# Exercise 1 — Azure AI Foundry project + gpt-4.1 deployment (Responses API).
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
MODEL_DEPLOYMENT=gpt-4.1

# Exercise 1 — Standalone Language service (TextAnalytics kind).
LANGUAGE_ENDPOINT=https://<language-account>.cognitiveservices.azure.com/
LANGUAGE_KEY=<paste primary key from az cognitiveservices account keys list>

# Exercise 2 — Standalone Translator (TextTranslation kind).
# TRANSLATOR_ENDPOINT is the global hostname; the region header routes to your resource.
TRANSLATOR_KEY=<paste primary key from az cognitiveservices account keys list>
TRANSLATOR_REGION=eastus2
TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/translate

# Exercise 3 — Standalone Speech (SpeechServices kind).
SPEECH_KEY=<paste primary key from az cognitiveservices account keys list>
SPEECH_REGION=eastus2
