# Azure AI Foundry project endpoint (used by AIProjectClient for keyless auth)
AZURE_AI_PROJECT_ENDPOINT=

# gpt-image-1 deployment name on the Foundry AIServices account
IMAGE_DEPLOYMENT=gpt-image-1

# gpt-4.1 multimodal chat deployment name on the Foundry AIServices account
CHAT_DEPLOYMENT=gpt-4.1

# Foundry AIServices account name (used by a few diagnostic az CLI commands)
FOUNDRY_ACCOUNT=

# Content Understanding REST endpoint (same host as the AIServices account)
CU_ENDPOINT=

# Content Understanding key (Ocp-Apim-Subscription-Key)
CU_KEY=

# Content Understanding preview REST API version
CU_API_VERSION=2024-12-01-preview
