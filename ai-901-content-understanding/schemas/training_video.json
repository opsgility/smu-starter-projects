{
  "description": "Outline a training video and extract per-scene topics and learning objectives",
  "scenario": "video",
  "fields": {
    "title": { "type": "string" },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start_seconds": { "type": "number" },
          "end_seconds":   { "type": "number" },
          "topic":         { "type": "string" }
        }
      }
    },
    "learning_objectives": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
