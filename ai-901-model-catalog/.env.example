# Foundry project endpoint — Foundry portal → Project → Overview → "Project endpoint"
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<project-name>
# Deployment name you want to inspect/deploy (any chat model, e.g. gpt-4o-mini)
MODEL_DEPLOYMENT_NAME=gpt-4o-mini
