@page "{id:int}"
@model BrightShelf.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Product Details";
}

<h1>Product Details</h1>

<div class="alert alert-info">
    <strong>Load time:</strong> @Model.LoadTimeMs ms
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <h5 class="card-title">@Model.Product.Name</h5>
        <span class="badge bg-secondary">@Model.Product.Category</span>
        <p class="card-text mt-2">@Model.Product.Description</p>
        <dl class="row">
            <dt class="col-sm-4">Price</dt>
            <dd class="col-sm-8">@Model.Product.Price.ToString("C")</dd>
            <dt class="col-sm-4">Stock</dt>
            <dd class="col-sm-8">@Model.Product.StockQuantity</dd>
            <dt class="col-sm-4">Created</dt>
            <dd class="col-sm-8">@Model.Product.CreatedAt.ToString("g")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
</div>
