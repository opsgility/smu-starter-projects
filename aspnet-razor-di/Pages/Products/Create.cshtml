@page
@model BrightShelf.Pages.Products.CreateModel

<!DOCTYPE html>
<html>
<head>
    <title>BrightShelf - Create Product</title>
</head>
<body>
    <h1>Create Product</h1>
    <form method="post">
        <div>
            <label asp-for="Product.Name">Name</label>
            <input asp-for="Product.Name" />
            <span asp-validation-for="Product.Name"></span>
        </div>
        <div>
            <label asp-for="Product.Price">Price</label>
            <input asp-for="Product.Price" />
            <span asp-validation-for="Product.Price"></span>
        </div>
        <div>
            <label asp-for="Product.Description">Description</label>
            <textarea asp-for="Product.Description"></textarea>
            <span asp-validation-for="Product.Description"></span>
        </div>
        <div>
            <label asp-for="Product.CategoryId">Category</label>
            <select asp-for="Product.CategoryId" asp-items="Model.CategoryOptions">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="Product.CategoryId"></span>
        </div>
        <button type="submit">Create</button>
    </form>
    <p><a asp-page="Index">Back to List</a></p>
</body>
</html>
