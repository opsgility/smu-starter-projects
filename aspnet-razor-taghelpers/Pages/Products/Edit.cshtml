@page "{id:int}"
@model BrightShelf.Pages.Products.EditModel

<h1>Edit Product</h1>

<form method="post">
    <input type="hidden" name="Product.Id" value="@Model.Product.Id" />
    <div>
        <label>Name</label>
        <input type="text" name="Product.Name" value="@Model.Product.Name" />
    </div>
    <div>
        <label>Author</label>
        <input type="text" name="Product.Author" value="@Model.Product.Author" />
    </div>
    <div>
        <label>Category</label>
        <select name="Product.Category">
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat" selected="@(Model.Product.Category == cat)">@cat</option>
            }
        </select>
    </div>
    <div>
        <label>Price</label>
        <input type="text" name="Product.Price" value="@Model.Product.Price" />
    </div>
    <div>
        <label>Description</label>
        <textarea name="Product.Description">@Model.Product.Description</textarea>
    </div>
    <button type="submit">Save</button>
</form>
<p><a href="/Products">Back to List</a></p>
