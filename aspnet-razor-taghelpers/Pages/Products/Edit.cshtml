@page "{id:int}"
@model BrightShelf.Pages.Products.EditModel

<!DOCTYPE html>
<html>
<head>
    <title>BrightShelf - Edit Product</title>
</head>
<body>
    <h1>Edit Product</h1>
    <nav>
        <a href="/">Home</a> |
        <a href="/Products">Products</a>
    </nav>

    <form method="post" action="/Products/Edit/@Model.Product.Id">
        <input type="hidden" name="Product.Id" value="@Model.Product.Id" />
        <div>
            <label for="Product_Name">Name</label>
            <input type="text" id="Product_Name" name="Product.Name" value="@Model.Product.Name" />
        </div>
        <div>
            <label for="Product_Price">Price</label>
            <input type="text" id="Product_Price" name="Product.Price" value="@Model.Product.Price" />
        </div>
        <div>
            <label for="Product_Description">Description</label>
            <textarea id="Product_Description" name="Product.Description">@Model.Product.Description</textarea>
        </div>
        <div>
            <label for="Product_CategoryId">Category</label>
            <select id="Product_CategoryId" name="Product.CategoryId">
                <option value="">-- Select Category --</option>
                <option value="1" @(Model.Product.CategoryId == 1 ? "selected" : "")>Electronics</option>
                <option value="2" @(Model.Product.CategoryId == 2 ? "selected" : "")>Accessories</option>
                <option value="3" @(Model.Product.CategoryId == 3 ? "selected" : "")>Peripherals</option>
            </select>
        </div>
        <button type="submit">Save</button>
    </form>
    <p><a href="/Products">Back to List</a></p>
</body>
</html>
