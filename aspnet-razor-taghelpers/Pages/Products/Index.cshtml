@page
@model BrightShelf.Pages.Products.IndexModel

<!DOCTYPE html>
<html>
<head>
    <title>BrightShelf - Products</title>
</head>
<body>
    <h1>Products</h1>
    <nav>
        <a href="/">Home</a> |
        <a href="/Products">Products</a>
    </nav>

    <p><a href="/Products/Create">Add New Product</a></p>

    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model.Products)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Price.ToString("C")</td>
                    <td>@(product.Category)</td>
                    <td>
                        <a href="/Products/Details/@product.Id">Details</a> |
                        <a href="/Products/Edit/@product.Id">Edit</a> |
                        <a href="/Products/Delete/@product.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
