# RetireScope local dev env
# DATABASE_URL points at the auto-provisioned Postgres in the lab container.
DATABASE_URL="postgresql://coder:coder@localhost:5432/labdb"

# Finnhub API key — get a free one at https://finnhub.io/register
FINNHUB_API_KEY=

# Lab container default — code-server proxies port 3000 at /proxy/3000.
BASE_PATH=/proxy/3000
NEXT_PUBLIC_BASE_PATH=/proxy/3000
