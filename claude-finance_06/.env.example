# RetireScope environment variables
# Copy to .env.local and fill in values. .env.local is gitignored.

# PostgreSQL — auto-provisioned in the lab container as labdb
DATABASE_URL="postgresql://coder:coder@localhost:5432/labdb"

# Finnhub API key for live stock quotes (Module 3+)
# Free signup at https://finnhub.io/register — no credit card required
FINNHUB_API_KEY=

# Anthropic Claude proxy (Module 7+)
# Auto-injected in the lab container; uncomment locally if running outside
# ANTHROPIC_BASE_URL=
# ANTHROPIC_API_KEY=
