# RetireScope local dev env
# DATABASE_URL points at the auto-provisioned Postgres in the lab container.
DATABASE_URL="postgresql://coder:coder@localhost:5432/labdb"

# Finnhub API key — get a free one at https://finnhub.io/register
FINNHUB_API_KEY=

# Anthropic Claude API
# In the lab container these two lines are auto-populated by the lab orchestrator
# at session start, so the AI Assistant works out of the box.
# When running locally, paste your own key from https://console.anthropic.com
# below and leave ANTHROPIC_BASE_URL empty (the SDK will use the default
# https://api.anthropic.com endpoint).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
