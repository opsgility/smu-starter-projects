# RetireScope environment variables
# Copy to .env if needed and fill in values.

# PostgreSQL — auto-provisioned in the lab container as labdb
DATABASE_URL="postgresql://coder:coder@localhost:5432/labdb"

# Finnhub API key for live stock quotes (Module 3+)
# Free signup at https://finnhub.io/register — no credit card required
FINNHUB_API_KEY=

# Anthropic Claude API (Module 7+)
# Lab container auto-populates these at session start.
# Locally, set ANTHROPIC_API_KEY to your own key from https://console.anthropic.com
# and leave ANTHROPIC_BASE_URL empty.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
