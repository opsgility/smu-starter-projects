{
  "name": "claude-mcp-lesson14-oauth",
  "version": "0.1.0",
  "description": "Lesson 14 starter: add OAuth 2.1 + PKCE bearer-token middleware to the Streamable HTTP server",
  "type": "module",
  "main": "dist/src/server.js",
  "bin": {
    "mcp-oauth-resource": "dist/src/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev:resource": "node dist/src/server.js",
    "dev:auth": "node dist/auth-server/server.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/src/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.0",
    "jose": "^5.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
