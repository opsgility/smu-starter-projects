# Resource server (this MCP server) configuration
PORT=3000
RESOURCE_URL=http://127.0.0.1:3000/mcp

# OAuth: must match what the auth-server issues in JWTs
OAUTH_ISSUER=http://127.0.0.1:4000
OAUTH_AUDIENCE=http://127.0.0.1:3000/mcp
OAUTH_JWKS_URI=http://127.0.0.1:4000/.well-known/jwks.json

# Upstream mock REST API (Lesson 16 — Northwind shipments)
MOCK_API_BASE=http://localhost:5000

# Local SQLite database (Lesson 16 — shipment history)
SQLITE_PATH=./data/shipments.db
