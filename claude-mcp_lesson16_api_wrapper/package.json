{
  "name": "claude-mcp-lesson16-api-wrapper",
  "version": "0.1.0",
  "description": "Lesson 16 starter: OAuth-protected Streamable HTTP MCP server with TODO scaffolds for API/database integration tools",
  "type": "module",
  "main": "dist/src/server.js",
  "bin": {
    "mcp-api-wrapper": "dist/src/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev:resource": "node dist/src/server.js",
    "dev:auth": "cd auth-server && npm run dev",
    "dev:mock": "cd mock-api && npm run dev",
    "seed": "node dist/data/seed.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/src/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.0",
    "jose": "^5.9.0",
    "lru-cache": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
