{
  "name": "claude-mcp-lesson18-observability",
  "version": "0.1.0",
  "description": "Lesson 18 starter: completed Lesson 16 server with TODO scaffolds for pino, OpenTelemetry, health checks, and graceful shutdown.",
  "type": "module",
  "main": "dist/src/server.js",
  "bin": {
    "mcp-observability": "dist/src/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev:resource": "node dist/src/server.js",
    "dev:auth": "cd auth-server && npm run dev",
    "dev:mock": "cd mock-api && npm run dev",
    "seed": "node dist/data/seed.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/src/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.0",
    "jose": "^5.9.0",
    "lru-cache": "^11.0.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
