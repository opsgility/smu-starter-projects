# Sentinel Intelligence Bureau Capstone - environment configuration
#
# Copy this file to `.env` and fill in the values from the lab's ARM deployment
# outputs in Exercise 1, Step 3.

# Foundry project endpoint (ends in /api/projects/<project-name>)
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/sib-osint-capstone

# Azure AI Search service endpoint
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net

# Azure AI Search connection ID inside the Foundry project (used by AgentsClient
# AzureAISearchTool). Format: /subscriptions/.../connections/<connection-name>
AZURE_SEARCH_CONNECTION_ID=

# Index seeded by seed_index.py
AZURE_SEARCH_INDEX=sib-osint-kb

# Chat model deployment name
MODEL_DEPLOYMENT=gpt-4.1

# Embedding model deployment name (text-embedding-3-large = 3072 dims)
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Application Insights connection string (workspace-based)
APPLICATIONINSIGHTS_CONNECTION_STRING=
