# Sentinel Intelligence Bureau RAG & Evaluation - environment configuration
#
# Copy this file to `.env` and fill in the values printed by the ARM deployment
# outputs in Exercise 1, Step 4.

# Foundry project endpoint (ends in /api/projects/<project-name>)
# NOT the .openai.azure.com AOAI endpoint.
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>

# Azure OpenAI (account-scoped) endpoint — used for embeddings, which do not
# route through the Foundry project endpoint. From ARM output azureOpenAIEndpoint.
AZURE_OPENAI_ENDPOINT=<from ARM output azureOpenAIEndpoint>

# Azure AI Search service endpoint
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net

# Index name created by Exercise 1. Do not change unless you also change it
# in every app/*.py reference.
AZURE_SEARCH_INDEX=sib-osint-rag

# Chat model deployment name (gpt-5-mini, deployed by the lab ARM template).
MODEL_DEPLOYMENT=gpt-5-mini

# Embedding model deployment name (text-embedding-3-small, 1536 dims).
EMBEDDING_DEPLOYMENT=text-embedding-3-small
